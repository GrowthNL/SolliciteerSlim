# Public variables (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional: privacy-friendly (cookieless) Plausible analytics. Leave empty to disable.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Server-only variables (never prefix these with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
# Stripe price IDs used by the webhook to map a subscription to a plan
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
